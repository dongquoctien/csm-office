{
  "name": "csm-office",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Realtime pixel-art office that visualizes Claude Code agent sessions from csm's /api/stream.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "serve": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check \"src/**/*.{ts,css}\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"test/**/*.ts\""
  },
  "dependencies": {
    "phaser": "^4.1.0"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.4",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "hono": "^4.12.23",
    "prettier": "^3.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
